# Configuración de Flask
FLASK_SECRET_KEY=tu_secret_key_aqui

# Supabase Configuration
SUPABASE_URL=tu_proyecto.supabase.co
SUPABASE_SERVICE_KEY=tu_service_role_key_de_supabase

# Google OAuth Credentials
# Consíguelas en: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=tu_client_id_de_google.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=tu_client_secret_de_google

# Importante: Configura la URI de redireccionamiento en la consola de Google como:
# http://127.0.0.1:5000/authorize

# Contraseña del admin por defecto (solo se usa al crear la BD por primera vez)
DEFAULT_ADMIN_PASSWORD=cambia_esta_contraseña

# Gmail — necesario para la función "Exportar a Gmail"
GMAIL_USER=tu_correo@gmail.com
GMAIL_APP_PASSWORD=tu_app_password_de_gmail
